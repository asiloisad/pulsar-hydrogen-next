'atom-workspace atom-text-editor:not([mini])':
  'cmdorctrl-enter': 'hydrogen-next:run'
  'shift-enter': 'hydrogen-next:run-and-move-down'
  'cmdorctrl-alt-enter': 'hydrogen-next:run-cell'
  'shift-alt-enter': 'hydrogen-next:run-cell-and-move-down'
  'cmdorctrl-shift-enter': 'hydrogen-next:run-all'
  'ctrl-shift-backspace': 'hydrogen-next:clear-results'
  'cmdorctrl-alt-backspace': 'hydrogen-next:clear-results'

'.hydrogen-next.kernel-picker atom-text-editor[mini]':
  'ctrl-enter': 'select-list:kernel'
  'f5': 'hydrogen-next:update-kernels'

'atom-workspace atom-text-editor.data-explorer-expression:not([mini])':
  'enter': 'core:confirm'
  'shift-enter': 'editor:newline'
  'escape': 'core:cancel'
  'tab': 'hydrogen-next:data-explorer-focus-toolbar'
  'shift-tab': 'hydrogen-next:data-explorer-focus-body'

'atom-workspace .data-explorer-toolbar-row':
  'left': 'hydrogen-next:data-explorer-toolbar-left'
  'right': 'hydrogen-next:data-explorer-toolbar-right'
  'enter': 'hydrogen-next:data-explorer-toolbar-confirm'
  'tab': 'hydrogen-next:data-explorer-focus-body'
  'shift-tab': 'hydrogen-next:data-explorer-focus-expression'

'atom-workspace atom-text-editor.inspector-expression:not([mini])':
  'enter': 'core:confirm'
  'shift-enter': 'editor:newline'
  'escape': 'core:cancel'
  'tab': 'hydrogen-next:inspector-focus-body'
  'shift-tab': 'hydrogen-next:inspector-focus-body'

'atom-workspace .data-explorer-body':
  'tab': 'hydrogen-next:data-explorer-focus-expression'
  'shift-tab': 'hydrogen-next:data-explorer-focus-toolbar'

'atom-workspace .data-explorer-canvas-wrap':
  'up': 'core:move-up'
  'down': 'core:move-down'
  'left': 'core:move-left'
  'right': 'core:move-right'
  'shift-up': 'core:select-up'
  'shift-down': 'core:select-down'
  'shift-left': 'core:select-left'
  'shift-right': 'core:select-right'
  'pageup': 'hydrogen-next:data-grid-page-up'
  'pagedown': 'hydrogen-next:data-grid-page-down'
  'shift-pageup': 'hydrogen-next:data-grid-select-page-up'
  'shift-pagedown': 'hydrogen-next:data-grid-select-page-down'
  'home': 'hydrogen-next:data-grid-move-to-row-start'
  'end': 'hydrogen-next:data-grid-move-to-row-end'
  'shift-home': 'hydrogen-next:data-grid-select-to-row-start'
  'shift-end': 'hydrogen-next:data-grid-select-to-row-end'
  'cmdorctrl-home': 'core:move-to-top'
  'cmdorctrl-end': 'core:move-to-bottom'
  'cmdorctrl-shift-home': 'core:select-to-top'
  'cmdorctrl-shift-end': 'core:select-to-bottom'

'atom-workspace .hydrogen-next.inspector .inspector-body':
  'up': 'hydrogen-next:inspector-scroll-up'
  'down': 'hydrogen-next:inspector-scroll-down'
  'tab': 'hydrogen-next:inspector-focus-expression'
  'shift-tab': 'hydrogen-next:inspector-focus-expression'

'atom-workspace atom-text-editor.watch-input:not([mini])':
  'enter': 'core:confirm'
  'shift-enter': 'editor:newline'

'atom-workspace .kernel-monitor-wrapper':
  'up': 'hydrogen-next:kernel-monitor-up'
  'down': 'hydrogen-next:kernel-monitor-down'
  'enter': 'hydrogen-next:kernel-monitor-open'
  'i': 'hydrogen-next:kernel-monitor-interrupt'
  'r': 'hydrogen-next:kernel-monitor-restart'
  's': 'hydrogen-next:kernel-monitor-shutdown'
